    { "lhs": "StructName", "rhs": "Named", "expect": false },
    { "lhs": "AnimalNamed", "rhs": "StructName", "expect": true },
    { "lhs": "AnimalNamed", "rhs": "Animal", "expect": true },
    { "lhs": "AnimalNamed", "rhs": "Named", "expect": false }
